# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Vapi ──────────────────────────────────────────────
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...       # From Vapi dashboard → Phone Numbers
VAPI_ASSISTANT_ID=...          # Existing Vapi Assistant to execute the call
VAPI_SERVER_PUBLIC_BASE_URL=   # Optional, e.g. https://xxxx.ngrok-free.app

# ── ElevenLabs ────────────────────────────────────────
ELEVENLABS_VOICE_ID=...        # From ElevenLabs → Voices

# ── App ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
RATE_LIMIT_PER_MINUTE=10

# ── Web Search Tool (Vapi tool-calls) ─────────────────
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT_SECONDS=10
